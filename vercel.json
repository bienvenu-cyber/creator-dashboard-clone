{
  "version": 2,
  "builds": [
    {
      "src": "landing-ghostdash-new/package.json",
      "use": "@vercel/next",
      "config": {
        "zeroConfig": true
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/landing-ghostdash-new/$1"
    }
  ]
}
